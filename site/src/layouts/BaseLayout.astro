---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav aria-label="Primary">
        <a href="/">Home</a>
        <a href="/featured">Featured synthesis</a>
        <a href="/methodology">Methodology</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
