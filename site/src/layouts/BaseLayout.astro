---
interface Props {
  title: string;
}

import { withBase } from '../lib/paths';
import {
  assertProductionTelemetryConfig,
  buildGaScriptUrl,
  isProductionTelemetryEnabled,
} from '../lib/analytics';
import { SCIPOP_ANALYTICS_CONSENT_KEY } from '../lib/consent';

const { title } = Astro.props;
const telemetryEnabled = isProductionTelemetryEnabled();
const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID ?? '';
const consentStorageKey = SCIPOP_ANALYTICS_CONSENT_KEY;
const gaScriptBaseUrl = telemetryEnabled ? buildGaScriptUrl('').replace(/\?id=$/, '') : '';

assertProductionTelemetryConfig();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <button
          type="button"
          class="menu-toggle"
          data-menu-button
          aria-expanded="false"
          aria-controls="primary-menu"
        >
          Menu
        </button>
        <nav id="primary-menu" class="primary-nav" aria-label="Primary" data-expanded="false">
          <a href={withBase('/')}>Home</a>
          <a href={withBase('/featured')}>Featured synthesis</a>
          <a href={withBase('/methodology')}>Methodology</a>
          <a href={withBase('/privacy')}>Privacy</a>
          <button type="button" class="privacy-settings-button" data-consent-manage>
            Privacy settings
          </button>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    {
      telemetryEnabled && (
        <div class="consent-banner" data-consent-banner hidden>
          <p>
            We use optional analytics cookies to understand site usage. You can accept or decline analytics
            tracking.
          </p>
          <div class="consent-actions">
            <button type="button" data-consent-accept>Accept analytics</button>
            <button type="button" data-consent-decline>Decline analytics</button>
          </div>
        </div>
      )
    }
    <script is:inline define:vars={{ telemetryEnabled, measurementId, consentStorageKey, gaScriptBaseUrl }}>
      const parseConsentState = (value) => {
        if (value === 'granted') {
          return 'granted';
        }

        if (value === 'denied') {
          return 'denied';
        }

        return 'unset';
      };

      const menuButton = document.querySelector('[data-menu-button]');
      const primaryMenu = document.getElementById('primary-menu');

      if (menuButton instanceof HTMLButtonElement && primaryMenu) {
        const closeMenu = () => {
          menuButton.setAttribute('aria-expanded', 'false');
          primaryMenu.dataset.expanded = 'false';
        };

        menuButton.addEventListener('click', () => {
          const isOpen = menuButton.getAttribute('aria-expanded') === 'true';
          const next = String(!isOpen);
          menuButton.setAttribute('aria-expanded', next);
          primaryMenu.dataset.expanded = next;
        });

        primaryMenu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', closeMenu);
        });
      }

      if (!telemetryEnabled) {
        return;
      }

      const consentBanner = document.querySelector('[data-consent-banner]');
      const consentAcceptButton = document.querySelector('[data-consent-accept]');
      const consentDeclineButton = document.querySelector('[data-consent-decline]');
      const consentManageButton = document.querySelector('[data-consent-manage]');
      let gaInitialized = false;

      const setBannerVisible = (visible) => {
        if (!consentBanner) {
          return;
        }

        if (visible) {
          consentBanner.removeAttribute('hidden');
          return;
        }

        consentBanner.setAttribute('hidden', '');
      };

      const initializeGa = () => {
        if (gaInitialized || !measurementId) {
          return;
        }

        gaInitialized = true;

        const script = document.createElement('script');
        script.async = true;
        script.src = `${gaScriptBaseUrl}?id=${measurementId}`;
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        window.gtag = window.gtag || function gtag() {
          window.dataLayer.push(arguments);
        };

        window.gtag('js', new Date());
        window.gtag('config', measurementId, {
          anonymize_ip: true,
          allow_google_signals: false,
          allow_ad_personalization_signals: false,
          page_path: window.location.pathname,
        });
      };

      const setConsent = (nextConsent) => {
        localStorage.setItem(consentStorageKey, nextConsent);
        setBannerVisible(false);

        if (nextConsent === 'denied') {
          const expiredDate = 'Thu, 01 Jan 1970 00:00:00 GMT';
          const cookieNames = document.cookie
            .split(';')
            .map((cookie) => cookie.trim().split('=')[0])
            .filter(Boolean);

          cookieNames
            .filter((cookieName) => cookieName === '_ga' || cookieName === '_gid' || cookieName.startsWith('_ga_'))
            .forEach((cookieName) => {
              document.cookie = `${cookieName}=; expires=${expiredDate}; path=/`;
            });

          if (measurementId) {
            window[`ga-disable-${measurementId}`] = true;
          }
        }

        if (nextConsent === 'granted') {
          if (measurementId) {
            window[`ga-disable-${measurementId}`] = false;
          }

          initializeGa();
        }
      };

      const consentState = parseConsentState(localStorage.getItem(consentStorageKey));

      if (consentState === 'unset') {
        setBannerVisible(true);
      }

      if (consentState === 'granted') {
        initializeGa();
      }

      consentAcceptButton?.addEventListener('click', () => setConsent('granted'));
      consentDeclineButton?.addEventListener('click', () => setConsent('denied'));

      consentManageButton?.addEventListener('click', () => {
        setBannerVisible(true);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --space-1: 0.75rem;
    --space-2: 1rem;
    --space-3: 1.5rem;
    --space-4: 2rem;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    line-height: 1.65;
    color: #1f2937;
    background-color: #ffffff;
  }

  .site-header {
    border-bottom: 1px solid #d1d5db;
    padding: var(--space-2);
  }

  .header-inner {
    max-width: 70ch;
    margin-inline: auto;
  }

  .menu-toggle,
  .primary-nav a,
  .privacy-settings-button {
    min-height: 44px;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
  }

  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #6b7280;
    background-color: #ffffff;
    color: #1f2937;
    cursor: pointer;
  }

  .primary-nav {
    margin-top: var(--space-2);
  }

  .primary-nav a {
    display: none;
    color: #1f2937;
    text-decoration: none;
    align-items: center;
  }

  .privacy-settings-button {
    display: none;
    border: 1px solid #6b7280;
    background-color: #ffffff;
    color: #1f2937;
    cursor: pointer;
    font: inherit;
  }

  .primary-nav[data-expanded='true'] a,
  .primary-nav[data-expanded='true'] .privacy-settings-button {
    display: flex;
  }

  .primary-nav a + a {
    margin-top: var(--space-1);
  }

  .primary-nav :is(a, .privacy-settings-button) + :is(a, .privacy-settings-button) {
    margin-top: var(--space-1);
  }

  .menu-toggle:focus-visible,
  .primary-nav a:focus-visible,
  .privacy-settings-button:focus-visible {
    outline: 3px solid #2563eb;
    outline-offset: 2px;
  }

  main {
    padding: var(--space-3) var(--space-2) var(--space-4);
  }

  .consent-banner {
    position: fixed;
    left: var(--space-2);
    right: var(--space-2);
    bottom: var(--space-2);
    border: 1px solid #d1d5db;
    border-radius: 0.5rem;
    padding: var(--space-2);
    background-color: #ffffff;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.12);
    max-width: 60ch;
    margin: 0 auto;
    z-index: 10;
  }

  .consent-banner p {
    margin-bottom: var(--space-2);
  }

  .consent-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .consent-actions button {
    min-height: 44px;
    border: 1px solid #6b7280;
    border-radius: 0.375rem;
    background: #ffffff;
    color: #1f2937;
    padding: 0.5rem 0.875rem;
    cursor: pointer;
  }

  .consent-actions button:focus-visible {
    outline: 3px solid #2563eb;
    outline-offset: 2px;
  }

  article {
    max-width: 70ch;
    margin-inline: auto;
  }

  article > * + * {
    margin-top: var(--space-3);
  }

  h1,
  h2,
  h3 {
    line-height: 1.25;
    margin: 0;
  }

  p {
    margin: 0;
  }

  section {
    padding-block: var(--space-1);
  }

  @media (min-width: 1024px) {
    body {
      font-size: 18px;
    }

    .header-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--space-2);
    }

    .menu-toggle {
      display: none;
    }

    .primary-nav {
      margin-top: 0;
      display: flex;
      gap: var(--space-1);
      align-items: center;
    }

    .primary-nav a,
    .primary-nav[data-expanded='false'] a,
    .privacy-settings-button,
    .primary-nav[data-expanded='false'] .privacy-settings-button {
      display: inline-flex;
      margin-top: 0;
    }

    main {
      padding-top: var(--space-4);
    }
  }
</style>
