---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';
import { DISCLAIMER_HEADING, resolveDisclaimer } from '../lib/disclaimer';

const featuredEntries = await getCollection('featured');
const overview = featuredEntries.find((entry) => entry.data.slug === 'research-group');

if (!overview) {
  throw new Error('Featured entry with slug "research-group" was not found.');
}

const { Content } = await render(overview);
const disclaimerText = resolveDisclaimer(overview.data.disclaimer_override);

if (!disclaimerText.trim()) {
  throw new Error('Missing disclaimer content for overview slug "research-group".');
}
---

<BaseLayout title="Research Group Overview">
  <article class="long-form-article" data-long-form="true">
    <header>
      <h1>Research Group Overview</h1>
      <p>{overview.data.summary}</p>
      <p>Reviewed: {overview.data.reviewed_at.toISOString().slice(0, 10)}</p>
    </header>

    <Content />

    <section aria-label={DISCLAIMER_HEADING}>
      <h2>{DISCLAIMER_HEADING}</h2>
      <p>{disclaimerText}</p>
    </section>
  </article>
</BaseLayout>
