---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

const pages = await getCollection('pages');
const privacy = pages.find((entry) => entry.data.slug === 'privacy');

if (!privacy) {
  throw new Error('Privacy page entry with slug "privacy" was not found.');
}

const { Content } = await render(privacy);
---

<BaseLayout title={privacy.data.title}>
  <article>
    <h1>{privacy.data.title}</h1>
    <Content />
  </article>
</BaseLayout>
