---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

const pages = await getCollection('pages');
const methodology = pages.find((entry) => entry.data.slug === 'methodology');

if (!methodology) {
  throw new Error('Methodology page entry with slug "methodology" was not found.');
}

const { Content } = await render(methodology);
---

<BaseLayout title={methodology.data.title}>
  <article class="long-form-article" data-long-form="true">
    <h1>{methodology.data.title}</h1>
    <Content />
  </article>
</BaseLayout>
