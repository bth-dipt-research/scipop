---
import { getCollection, render } from 'astro:content';

import BaseLayout from '../../layouts/BaseLayout.astro';
import { DISCLAIMER_HEADING, resolveDisclaimer } from '../../lib/disclaimer';

const featuredEntries = await getCollection('featured');
const featured = featuredEntries.find((entry) => entry.data.slug === 'research-group');

if (!featured) {
  throw new Error('Featured entry with slug "research-group" was not found.');
}

const { Content } = await render(featured);
const disclaimerText = resolveDisclaimer(featured.data.disclaimer_override);

if (!disclaimerText.trim()) {
  throw new Error('Missing disclaimer content for featured slug "research-group".');
}
---

<BaseLayout title={featured.data.title}>
  <article>
    <header>
      <h1>{featured.data.title}</h1>
      <p>{featured.data.summary}</p>
      <p>Reviewed: {featured.data.reviewed_at.toISOString().slice(0, 10)}</p>
    </header>

    <Content />

    <section aria-label={DISCLAIMER_HEADING}>
      <h2>{DISCLAIMER_HEADING}</h2>
      <p>{disclaimerText}</p>
    </section>
  </article>
</BaseLayout>
